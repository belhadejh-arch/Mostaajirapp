# ─────────────────────────────────────────────────────────────────
#  MOSTAJIR — Frontend Environment Variables
#  Copy this file to .env.local for local development
#  On Vercel: add these in Project Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────
# Project URL: Supabase Dashboard → Settings → API → Project URL
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Public anon key: Supabase Dashboard → Settings → API → anon public
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── App Domain ────────────────────────────────────────────────────
# Your production domain (used for redirect URLs in Chargily payments)
# Example: https://mostajir.vercel.app  or  https://mostajir.dz
VITE_APP_DOMAIN=https://your-domain.vercel.app
