# ─────────────────────────────────────────────
#  MOSTAJIR — متغيرات البيئة للفرونتند (Vercel)
# ─────────────────────────────────────────────
# انسخ هذا الملف إلى .env.local للتطوير المحلي
# على Vercel: أضف هذه المتغيرات في Settings → Environment Variables

# رابط مشروع Supabase (Dashboard → Settings → API → Project URL)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# المفتاح العام anon (Dashboard → Settings → API → anon public)
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
