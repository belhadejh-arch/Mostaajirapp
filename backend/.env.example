# ─────────────────────────────────────────────
#  MOSTAJIR — متغيرات البيئة للباكاند (Supabase Edge Functions)
# ─────────────────────────────────────────────
# يتم ضبط هذه المتغيرات في:
# Supabase Dashboard → Project Settings → Edge Functions → Secrets
# أو عبر CLI: supabase secrets set KEY=value

# ── Chargily Pay ──
# مفتاح API الخاص (من لوحة تحكم chargily.com)
CHARGILY_SECRET_KEY=your_chargily_secret_key

# ── Supabase Internal (تُضاف تلقائياً بواسطة Supabase) ──
# SUPABASE_URL=         (يُضاف تلقائياً)
# SUPABASE_SERVICE_ROLE_KEY=  (يُضاف تلقائياً)
# SUPABASE_ANON_KEY=    (يُضاف تلقائياً)
