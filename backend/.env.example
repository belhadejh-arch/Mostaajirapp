# ─────────────────────────────────────────────────────────────────
#  MOSTAJIR — Supabase Edge Functions Secrets
#  Set these via: supabase secrets set KEY=value
#  Or: Supabase Dashboard → Project Settings → Edge Functions → Secrets
# ─────────────────────────────────────────────────────────────────

# ── Chargily Pay ──────────────────────────────────────────────────
# Your secret API key from chargily.com dashboard
CHARGILY_SECRET_KEY=your_chargily_secret_key_here

# ── App Domain ────────────────────────────────────────────────────
# Your Vercel production domain (used for payment redirect fallbacks)
APP_DOMAIN=https://your-domain.vercel.app

# ── Supabase Internal (auto-injected by Supabase) ─────────────────
# These are added automatically — do NOT set them manually:
# SUPABASE_URL
# SUPABASE_SERVICE_ROLE_KEY
# SUPABASE_ANON_KEY
