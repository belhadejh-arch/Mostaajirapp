modules = ["nodejs-20", "postgresql-16"]
[nix]
channel = "stable-25_05"

[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend API"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd frontend && pnpm install && pnpm dev --port 5000 --host"
waitForPort = 5000

[[workflows.workflow]]
name = "Backend API"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "fuser -k 3001/tcp 2>/dev/null; pkill -f 'node index.js' 2>/dev/null; sleep 1; cd server && node index.js"
waitForPort = 3001

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000

[[ports]]
localPort = 5002
externalPort = 3002

[[ports]]
localPort = 5003
externalPort = 3003

[[ports]]
localPort = 5004
externalPort = 4200

[[ports]]
localPort = 5005
externalPort = 5000

[[ports]]
localPort = 5006
externalPort = 5173

[[ports]]
localPort = 5007
externalPort = 6000

[[ports]]
localPort = 5008
externalPort = 6800

[[ports]]
localPort = 5009
externalPort = 8000

[[ports]]
localPort = 5010
externalPort = 8008

[[ports]]
localPort = 5011
externalPort = 8080

[userenv]

[userenv.shared]

[userenv.development]

[deployment]
deploymentTarget = "autoscale"
run = ["node", "server/index.js"]
build = ["bash", "-c", "cd frontend && npm install -g pnpm && pnpm install && pnpm build"]
